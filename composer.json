{
    "name": "marko/filesystem",
    "description": "Filesystem interfaces and infrastructure for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/config": "@dev"
    },
    "require-dev": {
        "marko/testing": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Filesystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Filesystem\\Tests\\": "tests/"
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
